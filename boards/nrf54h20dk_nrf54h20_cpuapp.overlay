/*
 * Flipdots RS-485 via GPIO bit-bang UART on P9.04 (3.3 V)
 *
 * UARTE peripherals cannot route to GPIO port 9 on the nRF54H20
 * (confirmed: uart120, uart130, uart131, uart136 all fail on P9).
 * GPIO output works fine, so we bit-bang 9600-baud UART in software.
 *
 * CAN120 disabled to free P9.04/P9.05.
 */

&gpio9 {
	status = "okay";
};

&can120 {
	status = "disabled";
};
