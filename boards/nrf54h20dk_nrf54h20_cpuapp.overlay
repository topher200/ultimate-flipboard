/*
 * Device tree overlay for nRF54H20DK - Flipdots RS485 UART configuration
 *
 * DEBUG: Using uart120 with board-default pins P7.07 (TX) / P7.04 (RX)
 * to verify UART output on oscilloscope. uart120 pinctrl is already
 * configured in the board DTS, we just need to enable it.
 */

/ {
	aliases {
		flipdots-serial = &uart120;
	};
};

&uart120 {
	status = "okay";
	memory-regions = <&cpuapp_dma_region>;
	current-speed = <9600>;
};
